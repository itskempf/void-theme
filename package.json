{
  "name": "void-theme",
  "displayName": "VOID",
  "description": "Seven handcrafted VS Code themes spanning CRT noir, paper-warm ash, arcade blacklight, smoked jade, ember lacquer, broadcast pulse, and an ideal all-rounder.",
  "publisher": "void",
  "version": "0.1.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/itskempf/void-theme.git"
  },
  "bugs": {
    "url": "https://github.com/itskempf/void-theme/issues"
  },
  "homepage": "https://github.com/itskempf/void-theme#readme",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Themes"
  ],
  "activationEvents": [],
  "main": "./extension.js",
  "contributes": {
    "themes": [
      {
        "label": "VOID:Deep",
        "uiTheme": "vs-dark",
        "path": "./themes/void-deep-color-theme.json"
      },
      {
        "label": "VOID:Ash",
        "uiTheme": "vs-dark",
        "path": "./themes/void-ash-color-theme.json"
      },
      {
        "label": "VOID:Pulse",
        "uiTheme": "vs-dark",
        "path": "./themes/void-pulse-color-theme.json"
      },
      {
        "label": "VOID:Ideal",
        "uiTheme": "vs-dark",
        "path": "./themes/void-ideal-color-theme.json"
      },
      {
        "label": "VOID:Arcade",
        "uiTheme": "vs-dark",
        "path": "./themes/void-arcade-color-theme.json"
      },
      {
        "label": "VOID:Jade",
        "uiTheme": "vs-dark",
        "path": "./themes/void-jade-color-theme.json"
      },
      {
        "label": "VOID:Ember",
        "uiTheme": "vs-dark",
        "path": "./themes/void-ember-color-theme.json"
      }
    ]
  },
  "scripts": {
    "build": "node ./scripts/generate-themes.mjs",
    "package": "npm run build"
  },
  "license": "MIT"
}
