        "foreground": "#8b7cf8"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "meta.function entity.name",
        "meta.function punctuation.definition.parameters",
        "meta.function.parameters"
      ],
      "settings": {
        "foreground": "#6db8ff"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol",
        "constant.other.key",
        "string.template",
        "string.interpolated",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#7ecfa4"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character.numeric",
        "support.constant",
        "constant.other.color"
      ],
      "settings": {
        "foreground": "#e8a07a"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.class",
        "support.type",
        "meta.type.annotation",
        "entity.name.namespace"
      ],
      "settings": {
        "foreground": "#b08fff"
      }
    },
    {
      "scope": [
        "variable",
        "entity.name.variable",
        "support.variable",
        "meta.definition.variable",
        "meta.object-literal.key",
        "variable.other",
        "meta.property-name"
      ],
      "settings": {
        "foreground": "#c9c7d4"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "entity.name.parameter",
        "meta.function.parameters variable",
        "meta.function.parameters entity.name",
        "meta.function.parameters support.variable"
      ],
      "settings": {
        "foreground": "#c9c7d4"
      }
    },
    {
      "scope": [
        "operator",
        "punctuation",
        "meta.brace",
        "meta.delimiter",
        "punctuation.separator",
        "punctuation.terminator",
        "meta.property-list punctuation"
      ],
      "settings": {
        "foreground": "#242430"
      }
    },
    {
      "scope": [
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined",
        "constant.language.nan",
        "constant.language.infinity"
      ],
      "settings": {
        "foreground": "#8b7cf8"
      }
    },
    {
      "scope": [
        "meta.block meta.block",
        "meta.block meta.block meta.block",
        "meta.scope meta.scope",
        "meta.embedded",
        "meta.embedded source",
        "meta.string-contents",
        "meta.array punctuation",
        "meta.object-literal punctuation"
      ],
      "settings": {
        "foreground": "#2c2b37"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal",
        "invalid.deprecated",
        "entity.name.exception",
        "support.error"
      ],
      "settings": {
        "foreground": "#ff6b6b"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.underline"
      ],
      "settings": {
        "fontStyle": "underline"
      }
    }
  ],
