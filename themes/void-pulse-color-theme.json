  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment",
        "punctuation.definition.comment.begin",
        "punctuation.definition.comment.end",
        "meta.documentation",
        "string.quoted.docstring"
      ],
      "settings": {
        "foreground": "#5a6478",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "storage",
        "storage.type",
        "storage.modifier",
        "entity.name.tag",
        "entity.other.attribute-name",
        "support.type",
        "meta.preprocessor",
        "punctuation.definition.keyword"
      ],
      "settings": {
        "foreground": "#a88cff"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "meta.function entity.name",
        "meta.function punctuation.definition.parameters",
        "meta.function.parameters"
      ],
      "settings": {
        "foreground": "#7ac8ff"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol",
        "constant.other.key",
        "string.template",
        "string.interpolated",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#86e3b6"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character.numeric",
        "support.constant",
        "constant.other.color"
      ],
      "settings": {
        "foreground": "#ffb06f"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.class",
        "support.type",
        "meta.type.annotation",
        "entity.name.namespace"
      ],
      "settings": {
        "foreground": "#c7a2ff"
      }
    },
    {
      "scope": [
        "variable",
        "entity.name.variable",
        "support.variable",
        "meta.definition.variable",
        "meta.object-literal.key",
        "variable.other",
        "meta.property-name"
      ],
      "settings": {
        "foreground": "#e3e7f0"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "entity.name.parameter",
        "meta.function.parameters variable",
        "meta.function.parameters entity.name",
        "meta.function.parameters support.variable"
      ],
      "settings": {
        "foreground": "#e3e7f0"
      }
    },
    {
      "scope": [
        "operator",
        "punctuation",
        "meta.brace",
        "meta.delimiter",
        "punctuation.separator",
        "punctuation.terminator",
        "meta.property-list punctuation"
      ],
      "settings": {
        "foreground": "#373e4f"
      }
    },
    {
      "scope": [
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined",
        "constant.language.nan",
        "constant.language.infinity"
      ],
      "settings": {
        "foreground": "#a88cff"
      }
    },
    {
      "scope": [
        "meta.block meta.block",
        "meta.block meta.block meta.block",
        "meta.scope meta.scope",
        "meta.embedded",
        "meta.embedded source",
        "meta.string-contents",
        "meta.array punctuation",
        "meta.object-literal punctuation"
      ],
      "settings": {
        "foreground": "#343b4b"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal",
        "invalid.deprecated",
        "entity.name.exception",
        "support.error"
      ],
      "settings": {
        "foreground": "#ff7575"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.underline"
      ],
      "settings": {
        "fontStyle": "underline"
      }
    }
  ],
  "semanticTokenColors": {
    "comment": "#5a6478",
