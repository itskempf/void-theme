    "*.declaration": {
      "bold": true
    },
    "*.readonly": {
      "foreground": "#c7a2ff"
    },
    "*.static": {
      "foreground": "#a88cff"
    },
    "*.defaultLibrary": {
      "foreground": "#7ac8ff"
    },
    "*.deprecated": {
      "foreground": "#5a6478",
      "strikethrough": true
    },
    "*.modification": {
      "underline": true
    }
  }
