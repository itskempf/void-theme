    "editorGroup.border": "#1c1c22",
    "terminal.background": "#0a0a10",
    "terminal.foreground": "#eae8f8",
    "terminal.ansiBlack": "#0a0a10",
    "terminal.ansiRed": "#ff6b7a",
    "terminal.ansiGreen": "#8ddbb0",
    "terminal.ansiYellow": "#ffb88a",
    "terminal.ansiBlue": "#7dc4ff",
    "terminal.ansiMagenta": "#b8a4ff",
    "terminal.ansiCyan": "#78c9a0",
    "terminal.ansiWhite": "#eae8f8",
    "terminal.ansiBrightBlack": "#7a7890",
    "terminal.ansiBrightRed": "#ff6b7a",
    "terminal.ansiBrightGreen": "#8ddbb0",
    "terminal.ansiBrightYellow": "#ffb88a",
    "terminal.ansiBrightBlue": "#7dc4ff",
    "terminal.ansiBrightMagenta": "#b8a4ff",
    "terminal.ansiBrightCyan": "#78c9a0",
    "terminal.ansiBrightWhite": "#eae8f8",
    "gitDecoration.addedResourceForeground": "#78c9a0",
    "gitDecoration.modifiedResourceForeground": "#9d8cff",
    "gitDecoration.deletedResourceForeground": "#ff6b7a",
    "gitDecoration.untrackedResourceForeground": "#78c9a0",
    "editorError.foreground": "#ff6b7a",
    "editorWarning.foreground": "#e8a87c",
    "editorInfo.foreground": "#60aeff",
