    "editorBracketMatch.background": "#2a2840",
    "editorBracketMatch.border": "#9d8cff60",
    "editorGhostText.foreground": "#3f3e50",
    "editorSuggestWidget.background": "#141418",
    "editorSuggestWidget.border": "#1c1c22",
